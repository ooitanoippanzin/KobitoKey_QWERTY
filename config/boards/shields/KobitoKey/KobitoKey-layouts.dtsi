#include <physical_layouts.dtsi>

/ {
    /* キーボード全体の物理レイアウト（名前は任意） */
    kobitokey_layout: physical_layout_0 {
        compatible = "zmk,physical-layout";
        display-name = "KobitoKey Default";

        /* 必須：キー位置。順番は keymap のバインディング順と一致させる */
        /* ここでは 4行×10列（=合計40キー）を 1u グリッドで仮定 */
        /* 書式: <&key_physical_attrs  width height   x    y   rot  rx  ry> 単位は「キー単位(1u=100)」 */
        keys =
            /* Row 0 (y=0) */
              <&key_physical_attrs 100 100    0    0   0   0   0>
            , <&key_physical_attrs 100 100  100    0   0   0   0>
            , <&key_physical_attrs 100 100  200    0   0   0   0>
            , <&key_physical_attrs 100 100  300    0   0   0   0>
            , <&key_physical_attrs 100 100  400    0   0   0   0>
            , <&key_physical_attrs 100 100  600    0   0   0   0>

            , <&key_physical_attrs 100 100  950    0   0   0   0>
            , <&key_physical_attrs 100 100  1150    0   0   0   0>
            , <&key_physical_attrs 100 100  1250    0   0   0   0>
            , <&key_physical_attrs 100 100  1350    0   0   0   0>
            , <&key_physical_attrs 100 100  1450    0   0   0   0>
            , <&key_physical_attrs 100 100  1550    0   0   0   0>
            /* Row 1 (y=100) */
            , <&key_physical_attrs 100 100    0  100   0   0   0>
            , <&key_physical_attrs 100 100  100  100   0   0   0>
            , <&key_physical_attrs 100 100  200  100   0   0   0>
            , <&key_physical_attrs 100 100  300  100   0   0   0>
            , <&key_physical_attrs 100 100  400  100   0   0   0>
            , <&key_physical_attrs 100 100  500  100   0   0   0>
            , <&key_physical_attrs 100 100  600  100   0   0   0>
            , <&key_physical_attrs 100 100  700  100   0   0   0>

            , <&key_physical_attrs 100 100  850  100   0   0   0>
            , <&key_physical_attrs 100 100  950  100   0   0   0>
            , <&key_physical_attrs 100 100  1050  100   0   0   0>
            , <&key_physical_attrs 100 100  1150  100   0   0   0>
            , <&key_physical_attrs 100 100  1250  100   0   0   0>
            , <&key_physical_attrs 100 100  1350  100   0   0   0>
            , <&key_physical_attrs 100 100  1450  100   0   0   0>
            , <&key_physical_attrs 100 100  1550  100   0   0   0>
            /* Row 2 (y=200) */
            , <&key_physical_attrs 100 100    0  200   0   0   0>
            , <&key_physical_attrs 100 100  100  200   0   0   0>
            , <&key_physical_attrs 100 100  200  200   0   0   0>
            , <&key_physical_attrs 100 100  300  200   0   0   0>
            , <&key_physical_attrs 100 100  400  200   0   0   0>
            , <&key_physical_attrs 100 100  600  200   0   0   0>

            , <&key_physical_attrs 100 100  950  200   0   0   0>
            , <&key_physical_attrs 100 100  1150  200   0   0   0>
            , <&key_physical_attrs 100 100  1250  200   0   0   0>
            , <&key_physical_attrs 100 100  1350  200   0   0   0>
            , <&key_physical_attrs 100 100  1450  200   0   0   0>
            , <&key_physical_attrs 100 100  1550  200   0   0   0>
            /* Row 3 (y=300) */
            , <&key_physical_attrs 100 100  200  300   0   0   0>
            , <&key_physical_attrs 100 100  300  300   0   0   0>
            , <&key_physical_attrs 100 100  400  300   0   0   0>

            , <&key_physical_attrs 100 100  650  300   0   0   0>
            , <&key_physical_attrs 100 100  750  300   0   0   0>
            , <&key_physical_attrs 100 100  850  300   0   0   0>
            ;
    };
};
